{
  "schema_version": 1,
  "description": "Test-only H200 configuration for the mandatory-DFlash KV-reuse versus full-reprefill experiment. Production launchers must not source this file.",
  "defaults": {
    "question": "solve the equations 2x+2y=6 and 3x-y=5 for x and y",
    "model": "/workspace/models/opd-32b-deploy",
    "draft_model": "/workspace/models/dflash-32b-draft-v2test-phaseL",
    "gpu": "1",
    "max_new_tokens": 256,
    "kv_cache_dtype": "auto"
  },
  "environment": {
    "defaults": {
      "FLASHINFER_CUDA_ARCH_LIST": "9.0a",
      "FLASHINFER_USE_CUDA_NORM": "1",
      "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True",
      "SGLANG_DECODE_NUM_STAGES": "3",
      "SGLANG_DECODE_BLOCK_N": "32",
      "SGLANG_GQA_PACKED_EXTEND": "1",
      "TOKENIZERS_PARALLELISM": "false"
    },
    "required": {
      "SGLANG_ALLOW_OVERWRITE_LONGER_CONTEXT_LEN": "1",
      "SGLANG_ENABLE_OVERLAP_PLAN_STREAM": "1",
      "SGLANG_DFLASH_DRAFT_RING": "1",
      "SGLANG_DFLASH_DRAFT_RING_QUOTA": "4",
      "SGLANG_SWA_EVICTION_INTERVAL_MULTIPLIER": "0.125",
      "SGLANG_OPT_SWA_RELEASE_LEAF_LOCK_AFTER_WINDOW": "1"
    }
  },
  "engine_kwargs": {
    "speculative_algorithm": "DFLASH",
    "speculative_dflash_block_size": 8,
    "speculative_num_draft_tokens": 8,
    "speculative_draft_attention_backend": "triton",
    "attention_backend": "triton",
    "tp_size": 1,
    "context_length": 200000,
    "mem_fraction_static": 0.88,
    "chunked_prefill_size": 2048,
    "max_running_requests": 1,
    "stream_interval": 1,
    "swa_full_tokens_ratio": 0.1,
    "disable_radix_cache": true,
    "enable_cache_report": true,
    "enable_metrics": true,
    "random_seed": 0,
    "cuda_graph_max_bs_decode": 1,
    "cuda_graph_bs_decode": [
      1
    ],
    "cuda_graph_backend_prefill": "tc_piecewise",
    "cuda_graph_bs_prefill": [
      256,
      1024,
      2048
    ],
    "triton_attention_num_kv_splits": 32,
    "log_level": "warning"
  }
}
